pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        if getnamecallmethod() == "FireServer" and self.Name == "RemoteEvent" then
            local args = {...}
            if Options and Options.SpyPacket and Options.SpyPacket.Value then
                if typeof(args[1]) == "buffer" then
                    pcall(function()
                        local b = args[1]
                        if buffer.len(b) > 0 then
                            local id = buffer.readu8(b, 0)
                            Fluent:Notify({
                                Title = "📡 พบ Packet ID ใหม่!",
                                Content = "รหัสที่ส่งไปคือ: " .. tostring(id),
                                Duration = 8
                            })
                            print("📡 [Packet Spy] ID:", id)
                        end
                    end)
                end
            end
        end
        return oldNamecall(self, ...)
    end))
end)

