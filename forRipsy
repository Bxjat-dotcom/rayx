local function buySeed(seedName)
    local bytes = {PACKET_SEED, 0, string.len(seedName)}
    for i = 1, string.len(seedName) do table.insert(bytes, string.byte(seedName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function buyGear(itemName)
    local bytes = {PACKET_GEAR, 0, string.len(itemName)}
    for i = 1, string.len(itemName) do table.insert(bytes, string.byte(itemName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function sellAll()
    local bytes = { PACKET_SELL, 0, 25 }
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimDailyDeal()
    local bytes = { PACKET_DAILY, 0, 35 } 
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimMail(mailIdStr)
    if not string.match(mailIdStr, "^T&4:") then 
        mailIdStr = "T&4:" .. mailIdStr 
    end
    local bytes = {PACKET_MAIL, 1}
    for i = 1, string.len(mailIdStr) do table.insert(bytes, string.byte(mailIdStr, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

