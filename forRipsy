            antiAfkConnection:Disconnect()
            antiAfkConnection = nil
        end
    end
end

local function forceOpenMailbox()
    local foundAndFired = false
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                local action = (obj.ActionText or ""):lower()
                local objText = (obj.ObjectText or ""):lower()
                
                if name:find("mail") or name:find("inbox") or action:find("mail") or objText:find("mail") then
                    local oldDist = obj.MaxActivationDistance
                    local oldLOS = obj.RequiresLineOfSight
                    
                    obj.MaxActivationDistance = 999999
                    obj.RequiresLineOfSight = false 
                    
                    task.wait(0.1)
                    if fireproximityprompt then 
                        fireproximityprompt(obj, 1) 
                        fireproximityprompt(obj, 0)
                    end
                    
                    task.delay(1, function()
                        obj.MaxActivationDistance = oldDist
                        obj.RequiresLineOfSight = oldLOS
                    end)
                    
                    foundAndFired = true
                    break
                end
            elseif obj:IsA("ClickDetector") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                if name:find("mail") or name:find("inbox") then
                    if fireclickdetector then fireclickdetector(obj) end
                    foundAndFired = true
                    break
                end
            end
        end
    end)
    return foundAndFired
end

local function closeMailUI()
    pcall(function()
        local gui = LocalPlayer.PlayerGui:FindFirstChild("MailboxUI")
        if gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("Header") and gui.Frame.Header:FindFirstChild("ExitButton") then
            local exitBtn = gui.Frame.Header.ExitButton
            if getconnections then
                for _, conn in pairs(getconnections(exitBtn.Activated)) do pcall(function() conn:Fire() end) end
                for _, conn in pairs(getconnections(exitBtn.MouseButton1Click)) do pcall(function() conn:Fire() end) end
            else
                local inset = game:GetService("GuiService"):GetGuiInset() 
                local cx = exitBtn.AbsolutePosition.X + (exitBtn.AbsoluteSize.X / 2) + inset.X
                local cy = exitBtn.AbsolutePosition.Y + (exitBtn.AbsoluteSize.Y / 2) + inset.Y
                VIM:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
            end
        end
    end)
end

