-- [อัปเดตแก้ไข] ลูปการรับ Mail
local claimedMails = {}
AutoMail:OnChanged(function()
    if Options.AutoMail.Value then
        claimedMails = {}
    end
end)

task.spawn(function()
    local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"
    
    local function checkAndClaim(str)
        if type(str) ~= "string" then return end
        local match = string.match(str, uuidPattern)
        if match and not claimedMails[match] then
            claimedMails[match] = true
            claimMail(match)
            task.wait(Options.MailDelay.Value)
        end
    end

    local lastGCScan = 0

    while task.wait(2) do
        if Options.AutoMail.Value then
            
            -- [เช็คสถานะ UI] ถ้าหน้าต่าง UI จดหมายปิดอยู่ ให้สั่งเปิดใหม่ทันที!
            if not isMailUIOpen() then
                forceOpenMailbox()
                task.wait(1) -- หน่วงเวลา 1 วิ รอให้หน้า UI โหลดเสร็จก่อน
            end
            
            -- สแกน UI รับของ (ทำต่อหลังจากแน่ใจว่าหน้า UI เปิดอยู่)
            pcall(function()
                for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                    if not Options.AutoMail.Value then break end
                    checkAndClaim(obj.Name)
                    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                        checkAndClaim(obj.Text)
                    end
                    if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
                    for _, attrValue in pairs(obj:GetAttributes()) do checkAndClaim(attrValue) end
                end
            end)

            -- สแกน ReplicatedStorage
            pcall(function()
                for _, obj in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
                    if not Options.AutoMail.Value then break end
                    checkAndClaim(obj.Name)
                    if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
                end
            end)

            -- สแกนจาก Memory
            if tick() - lastGCScan > 10 then
                lastGCScan = tick()
                pcall(function()
                    for _, v in ipairs(getgc(true)) do
                        if not Options.AutoMail.Value then break end
                        if type(v) == "table" then
                            pcall(function()
                                for key, val in pairs(v) do
                                    if type(key) == "string" and #key >= 36 then checkAndClaim(key) end
                                    if type(val) == "string" and #val >= 36 then checkAndClaim(val) end
                                end
                            end)
                        end
                    end
                end)
            end
            
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Options.AutoDaily.Value then
            claimDailyDeal()
            task.wait(Options.DailyDelay.Value)
        end
    end
end)

