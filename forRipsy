-- ระบบแยกลากกับคลิกแบบละเอียด
local dragging = false
local isMoved = false
local dragStart, startPos

ToggleButton.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
dragging = true
isMoved = false
dragStart = input.Position
startPos = ToggleButton.Position
end
end)

UserInputService.InputChanged:Connect(function(input)
if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
local delta = input.Position - dragStart
if delta.Magnitude > 10 then -- ถ้านิ้วขยับเกิน 10 Pixel จะถือว่าเป็นการ "ลาก" ทันที
isMoved = true
ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end
end
end)

UserInputService.InputEnded:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
if dragging and not isMoved then
-- ถ้าปล่อยนิ้ว/เมาส์ โดยที่ไม่ได้ลากไปไหนเลย = "คลิก"
pcall(function()
-- วิธีที่ 1: สำหรับ Executor ที่มีระบบ keypress (ส่วนใหญ่จะเป็นมือถือหรือตัวระดับสูง)
if keypress then
keypress(0xA3) -- 0xA3 = RightControl
keyrelease(0xA3)
end
end)
pcall(function()
-- วิธีที่ 2: ระบบจำลองปุ่มมาตรฐาน
local vim = game:GetService("VirtualInputManager")
vim:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
vim:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
end)
end
dragging = false
end
end)

