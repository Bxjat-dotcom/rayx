local function buySeed(seedName)
    local bytes = {123, 0, string.len(seedName)}
    for i = 1, string.len(seedName) do table.insert(bytes, string.byte(seedName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function buyGear(itemName)
    local bytes = {127, 0, string.len(itemName)}
    for i = 1, string.len(itemName) do table.insert(bytes, string.byte(itemName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimDailyDeal()
    local bytes = { 183, 0, 29 }
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimMail(mailIdStr)
    if not string.match(mailIdStr, "^=&4:") then
        mailIdStr = "=&4:" .. mailIdStr
    end
    local bytes = {38, 1}
    for i = 1, string.len(mailIdStr) do table.insert(bytes, string.byte(mailIdStr, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function sellAll()
    local bytes = { 179, 0, 116 }
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local antiAfkConnection
local function toggleAntiAFK(state)
    if state then
        if not antiAfkConnection then
            antiAfkConnection = LocalPlayer.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end
    else
        if antiAfkConnection then
            antiAfkConnection:Disconnect()
            antiAfkConnection = nil
        end
    end
end

-- ฟังก์ชันจำลองการกดเปิดตู้จดหมาย
local function forceOpenMailbox()
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                local action = (obj.ActionText or ""):lower()
                local objText = (obj.ObjectText or ""):lower()
                
                if name:find("mail") or action:find("mail") or objText:find("mail") or name:find("inbox") then
                    local oldDist = obj.MaxActivationDistance
                    local oldLOS = obj.RequiresLineOfSight
                    
                    obj.MaxActivationDistance = 999999
                    obj.RequiresLineOfSight = false
                    
                    if fireproximityprompt then
                        fireproximityprompt(obj, 1)
                    end
                    
                    obj.MaxActivationDistance = oldDist
                    obj.RequiresLineOfSight = oldLOS
                end
            elseif obj:IsA("ClickDetector") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                if name:find("mail") or name:find("inbox") then
                    if fireclickdetector then
                        fireclickdetector(obj)
                    end
                end
            end
        end
    end)
end

-- [ใหม่] ฟังก์ชันเช็คว่าหน้าต่าง UI จดหมายกำลังเปิดอยู่หรือไม่
local function isMailUIOpen()
    local isOpen = false
    pcall(function()
        for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
            if obj:IsA("ScreenGui") or obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
                local name = string.lower(obj.Name)
                if name:find("mail") or name:find("inbox") then
                    -- เช็คสถานะการมองเห็น
                    if obj:IsA("ScreenGui") and obj.Enabled then
                        isOpen = true
                        break
                    elseif (obj:IsA("Frame") or obj:IsA("ScrollingFrame")) and obj.Visible then
                        local parentGui = obj:FindFirstAncestorOfClass("ScreenGui")
                        if parentGui and parentGui.Enabled then
                            isOpen = true
                            break
                        end
                    end
                end
            end
        end
    end)
    return isOpen
end

