local claimedMails = {}
Options.AutoMail:OnChanged(function()
    if Options.AutoMail.Value then claimedMails = {} end
end)

task.spawn(function()
    local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"
    local function checkAndClaim(str)
        if type(str) ~= "string" then return end
        local match = string.match(str, uuidPattern)
        if match and not claimedMails[match] then
            claimedMails[match] = true
            claimMail(match)
        end
    end

    local originalMailPos = nil

    while task.wait(1) do
        if Options.AutoMail.Value then
            if isFreshJoin and (tick() - scriptStartTime < 35) then
                -- รอพ้นช่วงล็อกตอนเข้าเกม
            else
                forceOpenMailbox()
                
                -- ซ่อน UI กล่องจดหมาย และสั่งปิด Effect เบลอหน้าจอ
                local mailGui
                pcall(function()
                    mailGui = LocalPlayer.PlayerGui:FindFirstChild("MailboxUI")
                    if mailGui then
                        mailGui.Enabled = false 
                        if mailGui:FindFirstChild("Frame") then
                            if not originalMailPos then
                                originalMailPos = mailGui.Frame.Position
                            end
                            mailGui.Frame.Position = UDim2.new(999, 0, 999, 0)
                        end
                    end
                end)

                -- ปิดอาการจอเบลอทันที
                removeBlur()

                task.wait(1.5)
                
                -- ลบเบลอซ้ำอีกรอบเพื่อความชัวร์ เผื่อเกมเพิ่งสั่งเปิด Effect
                removeBlur()

                pcall(function()
                    for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                        if not Options.AutoMail.Value then break end
                        checkAndClaim(obj.Name)
                        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then checkAndClaim(obj.Text) end
                        if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
                        for _, attrValue in pairs(obj:GetAttributes()) do checkAndClaim(attrValue) end
                    end
                end)

                pcall(function()
                    for _, obj in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
                        if not Options.AutoMail.Value then break end
                        checkAndClaim(obj.Name)
                        if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
                    end
                end)

                if Options.AutoMail.Value then 
                    pcall(function()
                        if mailGui then 
                            if mailGui:FindFirstChild("Frame") and originalMailPos then
                                mailGui.Frame.Position = originalMailPos
                            end
                            mailGui.Enabled = true 
                        end
                    end)
                    
                    closeMailUI() 
                    removeBlur() -- ลบเบลอตอนปิดด้วย
                end
                
                task.wait(math.max(2, Options.MailDelay.Value))
            end
        end
    end
end)

