local function buySeed(seedName)
    local bytes = {123, 0, string.len(seedName)}
    for i = 1, string.len(seedName) do table.insert(bytes, string.byte(seedName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function buyGear(itemName)
    local bytes = {127, 0, string.len(itemName)}
    for i = 1, string.len(itemName) do table.insert(bytes, string.byte(itemName, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimDailyDeal()
    local bytes = { 183, 0, 29 }
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function claimMail(mailIdStr)
    if not string.match(mailIdStr, "^=&4:") then
        mailIdStr = "=&4:" .. mailIdStr
    end
    local bytes = {38, 1}
    for i = 1, string.len(mailIdStr) do table.insert(bytes, string.byte(mailIdStr, i)) end
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local function sellAll()
    local bytes = { 179, 0, 116 }
    local b = buffer.create(#bytes)
    for i = 1, #bytes do buffer.writeu8(b, i - 1, bytes[i]) end
    Event:FireServer(b)
end

local antiAfkConnection
local function toggleAntiAFK(state)
    if state then
        if not antiAfkConnection then
            antiAfkConnection = LocalPlayer.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end
    else
        if antiAfkConnection then
            antiAfkConnection:Disconnect()
            antiAfkConnection = nil
        end
    end
end

local function forceOpenMailbox()
    local foundAndFired = false
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                local action = (obj.ActionText or ""):lower()
                local objText = (obj.ObjectText or ""):lower()
                
                if name:find("mail") or action:find("mail") or objText:find("mail") or name:find("inbox") then
                    local oldDist = obj.MaxActivationDistance
                    local oldLOS = obj.RequiresLineOfSight
                    
                    obj.MaxActivationDistance = 999999
                    obj.RequiresLineOfSight = false
                    
                    if fireproximityprompt then fireproximityprompt(obj, 1) end
                    
                    obj.MaxActivationDistance = oldDist
                    obj.RequiresLineOfSight = oldLOS
                    
                    foundAndFired = true
                    break
                end
            elseif obj:IsA("ClickDetector") then
                local name = (obj.Parent and obj.Parent.Name or ""):lower()
                if name:find("mail") or name:find("inbox") then
                    if fireclickdetector then fireclickdetector(obj) end
                    foundAndFired = true
                    break
                end
            end
        end
    end)
    return foundAndFired
end

local function closeMailUI()
    pcall(function()
        local gui = LocalPlayer.PlayerGui:FindFirstChild("MailboxUI")
        if gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("Header") and gui.Frame.Header:FindFirstChild("ExitButton") then
            local exitBtn = gui.Frame.Header.ExitButton
            
            local fakeInputBegin = {UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.Begin}
            local fakeInputEnd = {UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.End}

            if getconnections then
                for _, conn in pairs(getconnections(exitBtn.InputBegan)) do
                    pcall(function() conn:Fire(fakeInputBegin) end)
                end
                task.wait(0.05)
                for _, conn in pairs(getconnections(exitBtn.InputEnded)) do
                    pcall(function() conn:Fire(fakeInputEnd) end)
                end
                for _, conn in pairs(getconnections(exitBtn.Activated)) do pcall(function() conn:Fire() end) end
                for _, conn in pairs(getconnections(exitBtn.MouseButton1Click)) do pcall(function() conn:Fire() end) end
            else
                local guiService = game:GetService("GuiService")
                local inset = guiService:GetGuiInset() 
                
                local cx = exitBtn.AbsolutePosition.X + (exitBtn.AbsoluteSize.X / 2) + inset.X
                local cy = exitBtn.AbsolutePosition.Y + (exitBtn.AbsoluteSize.Y / 2) + inset.Y
                
                VIM:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
            end
        end
    end)
end

