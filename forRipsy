-- ลูปการทำงาน (Loops)
-----------------------------------------------------------------------------
task.spawn(function()
    while task.wait() do
        if Options.AutoSeed.Value then
            for seedName, isSelected in pairs(Options.SeedSelect.Value) do
                if isSelected and Options.AutoSeed.Value then
                    buySeed(seedName)
                    task.wait(Options.SeedDelay.Value)
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Options.AutoGear.Value then
            for gearName, isSelected in pairs(Options.GearSelect.Value) do
                if isSelected and Options.AutoGear.Value then
                    buyGear(gearName)
                    task.wait(Options.GearDelay.Value)
                end
            end
        end
    end
end)

local claimedMails = {}
AutoMail:OnChanged(function()
    if Options.AutoMail.Value then
        claimedMails = {}
    end
end)

task.spawn(function()
    local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"
    local function checkAndClaim(str)
        if not str then return end
        local match = string.match(tostring(str), uuidPattern)
        if match and not claimedMails[match] then
            claimedMails[match] = true
            claimMail(match)
            task.wait(Options.MailDelay.Value)
        end
    end

    while task.wait(2) do
        if Options.AutoMail.Value then
            for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                if not Options.AutoMail.Value then break end
                checkAndClaim(obj.Name)
                if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                    checkAndClaim(obj.Text)
                end
                if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
                for _, attrValue in pairs(obj:GetAttributes()) do checkAndClaim(attrValue) end
            end
            for _, obj in ipairs(LocalPlayer:GetDescendants()) do
                if not Options.AutoMail.Value then break end
                checkAndClaim(obj.Name)
                if obj:IsA("StringValue") then checkAndClaim(obj.Value) end
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Options.AutoDaily.Value then
            claimDailyDeal()
            task.wait(Options.DailyDelay.Value)
        end
    end
end)

