-- ระบบลาก UI
local dragging, dragInput, dragStart, startPos, startClickPos

ToggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleBtn.Position
        startClickPos = input.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ToggleBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        ToggleBtn.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X, 
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- เมื่อแตะ/คลิกปุ่ม จะส่งคำสั่งเสมือนว่ากดปุ่ม LeftControl บนคีย์บอร์ด (เพื่อให้ Fluent ย่อ/ขยายตัวเอง)
ToggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if (input.Position - startClickPos).Magnitude < 15 then
            -- จำลองการกดปุ่ม Ctrl ค้างไว้และปล่อย
            VIM:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
            task.wait()
            VIM:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
        end
    end
end)

